# Port expose par le gateway
PORT=8001

# URLs cibles en execution locale (hors Docker)
AUTH_SERVICE_URL=http://localhost:8000
AGENCE_SERVICE_URL=http://localhost:8002

# En Docker Compose, ces variables sont surchargees par:
# AUTH_SERVICE_URL=http://auth_service:8000
# AGENCE_SERVICE_URL=http://agence_service:8002
