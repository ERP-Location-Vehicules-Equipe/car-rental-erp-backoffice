@startuml
title MLD - ERP Location Voitures (Complet)

entity clients {
  +id : bigint <<PK>>
  nom_complet : varchar
  cin : varchar
  telephone : varchar
  email : varchar
  adresse : varchar
  created_at : datetime
}

entity agences {
  +id : bigint <<PK>>
  nom : varchar
  adresse : varchar
  ville : varchar
  telephone : varchar
  created_at : datetime
}

entity categories {
  +id : bigint <<PK>>
  libelle : varchar
  tarif_jour_base : decimal
}

entity marques {
  +id : bigint <<PK>>
  nom : varchar
}

entity modeles {
  +id : bigint <<PK>>
  marque_id : bigint <<FK>>
  nom : varchar
}

entity vehicules {
  +id : bigint <<PK>>
  agence_id : bigint <<FK>>
  modele_id : bigint <<FK>>
  categorie_id : bigint <<FK>>
  immatriculation : varchar
  date_mise_en_circulation : date
  kilometrage : int
  statut : varchar
  valeur_achat : decimal
  photo_url : varchar
  created_at : datetime
}

entity locations {
  +id : bigint <<PK>>
  client_id : bigint <<FK>>
  vehicule_id : bigint <<FK>>
  agence_depart_id : bigint <<FK>>
  agence_retour_id : bigint <<FK>>
  date_debut : datetime
  date_fin_prevue : datetime
  date_retour_reelle : datetime
  tarif_jour : decimal
  montant_total : decimal
  statut : varchar
  created_at : datetime
}

entity factures {
  +id : bigint <<PK>>
  location_id : bigint <<FK>>
  numero : varchar
  montant_ht : decimal
  tva : decimal
  montant_ttc : decimal
  date_emission : datetime
  statut : varchar
}

entity paiements {
  +id : bigint <<PK>>
  facture_id : bigint <<FK>>
  montant : decimal
  mode : varchar
  date_paiement : datetime
  reference : varchar
}

entity transferts {
  +id : bigint <<PK>>
  vehicule_id : bigint <<FK>>
  agence_source_id : bigint <<FK>>
  agence_destination_id : bigint <<FK>>
  date_depart : datetime
  date_arrivee_prevue : datetime
  date_arrivee_reelle : datetime
  etat : varchar
}

entity entretiens {
  +id : bigint <<PK>>
  vehicule_id : bigint <<FK>>
  type : varchar
  date_debut : date
  date_fin : date
  cout : decimal
  notes : text
}

entity charges {
  +id : bigint <<PK>>
  vehicule_id : bigint <<FK>>
  agence_id : bigint <<FK>>
  type : varchar
  categorie_charge : varchar
  montant : decimal
  date_charge : datetime
  description : text
}

entity utilisateurs {
  +id : bigint <<PK>>
  agence_id : bigint <<FK>>
  nom : varchar
  email : varchar
  password : varchar
  role : varchar
  actif : boolean
  created_at : datetime
}

entity notifications {
  +id : bigint <<PK>>
  utilisateur_id : bigint <<FK>>
  type : varchar
  reference_id : bigint
  message : text
  lu : boolean
  created_at : datetime
}

entity comptes_tresorerie {
  +id : bigint <<PK>>
  nom : varchar
  type : varchar
  solde_actuel : decimal
}

@enduml